# ─── Anthropic (REQUIRED) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Engagement Authorization (REQUIRED before any scan/exploit) ───────────────
# Comma-separated list of authorized IPs, CIDR ranges, or hostnames
AUTHORIZED_TARGETS=192.168.1.0/24,10.0.0.5,lab.internal
# Engagement ID for audit trail
ENGAGEMENT_ID=ENG-2026-001
# Engagement name / client
ENGAGEMENT_NAME=Internal Red Team - Lab
# Operator name (goes into every audit log entry)
OPERATOR_NAME=your-name
# Hard expiry (ISO 8601) — agents will refuse to operate after this
ENGAGEMENT_EXPIRY=2026-12-31T23:59:59

# ─── External Recon APIs (optional, agents degrade gracefully without them) ────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
NVD_API_KEY=                # NIST NVD — higher rate limits with a key

# ─── Metasploit RPC (optional — exploitation agent) ───────────────────────────
MSFRPC_HOST=127.0.0.1
MSFRPC_PORT=55553
MSFRPC_USER=msf
MSFRPC_PASS=change_me

# ─── MCP servers (comma-separated, see mcp_layer/mcp_config.py) ───────────────
# 'web' (fetch server) works out of the box — installed via requirements.txt.
# 'filesystem' needs Node; 'shodan' needs uv. Empty = no MCP, native tools only.
MCP_ENABLED_SERVERS=web

# ─── Model preferences ─────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-7          # orchestrator + agent model
CLAUDE_FAST_MODEL=claude-haiku-4-5    # optional fast model for simple agents
# Effort: low | medium | high | xhigh | max  (xhigh = best for agentic work)
ORCHESTRATOR_EFFORT=xhigh
AGENT_EFFORT=high

# ─── Data paths ────────────────────────────────────────────────────────────────
EVIDENCE_DIR=./data/evidence
REPORTS_DIR=./data/reports
KNOWLEDGE_DIR=./data/knowledge

# ─── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_random_secret

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
