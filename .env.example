# ─── Anthropic (REQUIRED) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Engagement Authorization (REQUIRED before any scan/exploit) ───────────────
# Comma-separated list of authorized IPs, CIDR ranges, or hostnames
AUTHORIZED_TARGETS=192.168.1.0/24,10.0.0.5,lab.internal
# Engagement ID for audit trail
ENGAGEMENT_ID=ENG-2026-001
# Engagement name / client
ENGAGEMENT_NAME=Internal Red Team - Lab
# Operator name (goes into every audit log entry)
OPERATOR_NAME=your-name
# Hard expiry (ISO 8601) — agents will refuse to operate after this
ENGAGEMENT_EXPIRY=2026-12-31T23:59:59

# ─── External Recon APIs (optional, agents degrade gracefully without them) ────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
NVD_API_KEY=                # NIST NVD — higher rate limits with a key

# ─── MCP fleet API keys (5D — optional; servers degrade gracefully) ───────────
GREYNOISE_API_KEY=          # threatintel MCP
VIRUSTOTAL_API_KEY=         # threatintel MCP
SIEM_TOKEN=                 # siem MCP (read-only)

# ─── Web application testing (C1 — webapp agent: OWASP ZAP + Nuclei) ──────────
# Optional; the webapp agent degrades gracefully if ZAP/nuclei are unreachable.
ZAP_API_URL=http://127.0.0.1:8090   # ZAP daemon: zaproxy -daemon -port 8090 -config api.key=<key>
ZAP_API_KEY=                         # ZAP API key (empty = ZAP's disabled-key mode)
NUCLEI_PATH=nuclei                   # nuclei binary (Kali: apt install nuclei; nuclei -update-templates)
# Active scanning (ZAP active scan / nuclei DAST) is INTRUSIVE — sends attack traffic.
# Leave false unless you hold signed written authorization for THIS engagement.
WEBAPP_ACTIVE_SCAN_AUTHORIZED=false

# ─── Active Directory / Windows testing (C5 — 'ad' MCP server) ────────────────
# BloodHound CE REST + NetExec/Impacket/Certipy (subprocess). Optional; degrades
# gracefully. Kali: pipx install bloodhound netexec impacket certipy-ad; BHCE via docker.
BLOODHOUND_CE_URL=http://127.0.0.1:8080
BLOODHOUND_CE_TOKEN=
NETEXEC_PATH=nxc
# State-changing AD actions (nxc command exec, Certipy cert request) are intrusive —
# leave false unless you hold signed written authorization. Read/enum is allowed in scope.
AD_STATE_CHANGE_AUTHORIZED=false

# ─── Phishing / social engineering (C6 — 'social_eng' GoPhish server) ─────────
# Campaigns are blocked unless PHISHING_AUTHORIZED=true AND a human approver is named
# at launch, and every target must be inside AUTHORIZED_EMAIL_DOMAINS.
GOPHISH_API_URL=                         # e.g. https://127.0.0.1:3333
GOPHISH_API_KEY=
AUTHORIZED_EMAIL_DOMAINS=                 # comma-separated, e.g. acme.co.ke,*.acme.com
PHISHING_AUTHORIZED=false                 # written-authorization flag for THIS engagement

# ─── Metasploit RPC (optional — exploitation agent) ───────────────────────────
MSFRPC_HOST=127.0.0.1
MSFRPC_PORT=55553
MSFRPC_USER=msf
MSFRPC_PASS=change_me

# ─── MCP servers (comma-separated, see mcp_layer/mcp_config.py) ───────────────
# 'web' (fetch) + 'filesystem' (read-only evidence access) work out of the box.
# 'filesystem' needs Node (npx); 'shodan' needs uv. 'webapp' (ZAP+Nuclei) needs a
# running ZAP daemon + nuclei on the host. Empty = native tools only.
MCP_ENABLED_SERVERS=web,filesystem

# ─── Model preferences ─────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-8          # orchestrator + agent model
CLAUDE_FAST_MODEL=claude-haiku-4-5    # optional fast model for simple agents
# Effort: low | medium | high | xhigh | max  (xhigh = best for agentic work)
ORCHESTRATOR_EFFORT=xhigh
AGENT_EFFORT=high

# ─── Cost controls (optional — all off by default, existing .env keeps working) ─
# Hard USD ceiling for the engagement. 0 = no ceiling.
ENGAGEMENT_BUDGET_USD=0
# When the ceiling is hit: downgrade to CLAUDE_FAST_MODEL, or halt cleanly.
ON_BUDGET_EXCEEDED=downgrade          # downgrade | halt
# Summarise oversized tool output via the fast model before it enters Opus context.
COMPRESS_TOOL_OUTPUT=false
# Detect + spotlight prompt-injection in untrusted tool output (defense-in-depth)
ENABLE_UNTRUSTED_CONTENT_DEFENSE=false
# Clear old tool output from the running history past N chars (long-run context)
COMPACT_HISTORY=false
COMPACT_AFTER_CHARS=60000
# Rank tradecraft recall by embedding similarity (needs sentence-transformers)
MEMORY_SEMANTIC_RECALL=false

# ─── Finding lifecycle (C2) ────────────────────────────────────────────────────
# Findings flow candidate -> confirmed (deterministic re-test) -> approved (human).
# When true, ONLY human-approved findings may be reported/sent (strict workflow).
# Default false keeps existing behavior (report everything) — non-breaking.
REQUIRE_FINDING_APPROVAL=false

# ─── Attack graph (2A — optional Neo4j mirror; empty = in-process networkx) ────
# Live BloodHound-style browser: `docker-compose up -d neo4j`, then set NEO4J_URI.
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Tracing (5C — optional OpenTelemetry) ────────────────────────────────────
# Live dashboard: uvicorn api.server:app → http://localhost:8000/dashboard (no key).
# Distributed traces: `docker-compose up -d jaeger`, set the endpoint below, and
# `pip install opentelemetry-exporter-otlp-proto-http`. Empty = tracing off.
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── Data paths ────────────────────────────────────────────────────────────────
EVIDENCE_DIR=./data/evidence
REPORTS_DIR=./data/reports
KNOWLEDGE_DIR=./data/knowledge

# ─── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_random_secret
# CORS origins (comma-separated). "*" = open (localhost default). Lock down a
# networked deployment with explicit origins, e.g. https://ops.example.com
API_CORS_ORIGINS=*

# ─── Multi-tenant SaaS backend (C7 — all optional, safe dev defaults) ─────────
# Dev/test uses sqlite + a synchronous job runner; set these for production.
DATABASE_URL=                 # PostgreSQL DSN in prod (row-level security applied); empty → sqlite
SAAS_DB_PATH=                 # sqlite path override; empty → <knowledge>/../saas.db
REDIS_URL=                    # Celery broker; empty → synchronous in-process runner
VAULT_ADDR=                   # HashiCorp Vault; empty → env secret provider
VAULT_TOKEN=
JWT_SECRET=                   # JWT signing key (≥32 bytes in prod); empty → secrets provider / API_SECRET_KEY
JWT_TTL_SECONDS=3600
SAAS_ENCRYPTION_KEY=          # Fernet key for at-rest secret encryption (generate with saas.crypto.generate_key)

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
